# Gogi Eats staging template
# This file is intentionally fake and safe to commit.
# Use only with an isolated staging database and test provider credentials.

APP_ENV=staging
DATABASE_ENV=staging
NEXT_PUBLIC_APP_URL=https://preview-staging.example.vercel.app
APP_URL=https://preview-staging.example.vercel.app
NEXTAUTH_URL=https://preview-staging.example.vercel.app

DATABASE_URL=mysql://STAGING_USER:STAGING_PASSWORD@STAGING_HOST:3306/gogi_staging
DIRECT_URL=mysql://STAGING_USER:STAGING_PASSWORD@STAGING_HOST:3306/gogi_staging
DB_HOST=STAGING_HOST
DB_PORT=3306
DB_NAME=gogi_staging
DB_USER=STAGING_USER
DB_PASSWORD=STAGING_PASSWORD
DB_PASS=STAGING_PASSWORD
DB_REQUIRE_SSL=true
DB_SSL_CA=-----BEGIN CERTIFICATE-----\\nSTAGING_CA_PLACEHOLDER\\n-----END CERTIFICATE-----
DB_CA=
DB_POOL_CONNECTION_LIMIT=3
DB_POOL_QUEUE_LIMIT=25
PRISMA_CONNECTION_LIMIT=3
PRISMA_POOL_TIMEOUT=20

PRODUCTION_DB_NAME=gogi_prod
PRODUCTION_DB_HOST_FINGERPRINT=PROD_HOST_FINGERPRINT_PLACEHOLDER
PRODUCTION_DB_USER_FINGERPRINT=PROD_USER_FINGERPRINT_PLACEHOLDER

JWT_SECRET=REPLACE_WITH_A_MINIMUM_32_CHAR_STAGING_JWT_SECRET
NEXTAUTH_SECRET=REPLACE_WITH_A_MINIMUM_32_CHAR_STAGING_NEXTAUTH_SECRET
AUTH_SECRET=REPLACE_WITH_A_MINIMUM_32_CHAR_STAGING_AUTH_SECRET
SESSION_SECRET=REPLACE_WITH_A_MINIMUM_32_CHAR_STAGING_SESSION_SECRET
ADMIN_SECRET=REPLACE_WITH_A_MINIMUM_32_CHAR_STAGING_ADMIN_SECRET
AUTH_COOKIE_DOMAIN=preview-staging.example.vercel.app
AUTH_SESSION_HOURS=12
JWT_EXPIRES_IN=12h
JWT_EXPIRATION=12h

NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=APP_TEST-STAGING-PUBLIC-KEY
MERCADOPAGO_ACCESS_TOKEN=APP_TEST-STAGING-ACCESS-TOKEN
MERCADOPAGO_WEBHOOK_SECRET=REPLACE_WITH_A_MINIMUM_32_CHAR_STAGING_MP_WEBHOOK_SECRET
NEXT_PUBLIC_MERCADOPAGO_DEBUG=1

NEXT_PUBLIC_TRANSFER_BANK=Banco QA Staging
NEXT_PUBLIC_TRANSFER_HOLDER=Titular QA Staging
NEXT_PUBLIC_TRANSFER_CLABE=111111111111111111
NEXT_PUBLIC_TRANSFER_ACCOUNT_NUMBER=1111111111

RESEND_API_KEY=re_test_staging_placeholder
EMAIL_FROM=Gogi Eats Staging <staging@gogieats.test>
EMAIL_VERIFICATION_ENABLED=true
SMTP_HOST=smtp.staging.example.test
SMTP_USER=staging_smtp_user
SMTP_PASS=staging_smtp_password

CLOUDINARY_CLOUD_NAME=staging-cloud-name
CLOUDINARY_API_KEY=1234567890
CLOUDINARY_API_SECRET=staging_cloudinary_secret
STORAGE_BUCKET_NAME=staging-gogieats-bucket
AWS_ACCESS_KEY_ID=AWS_STAGING_ACCESS_KEY_ID_PLACEHOLDER
AWS_SECRET_ACCESS_KEY=AWS_STAGING_SECRET_ACCESS_KEY_PLACEHOLDER

NEXT_PUBLIC_MAPS_API_KEY=maps_public_staging_placeholder
SENTRY_DSN=https://public@example.ingest.sentry.io/654321

PASSWORD_PEPPER=REPLACE_WITH_A_MINIMUM_32_CHAR_STAGING_PASSWORD_PEPPER
PASSWORD_RESET_TOKEN_MINUTES=30
SALT_ROUNDS=12

ENABLE_INTERNAL_TOOLS=false
ALLOW_STAGING_DB_WRITES=false
SEED_DEMO_DATA=false
