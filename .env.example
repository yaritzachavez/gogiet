# Gogi Eats environment template
# Copy to a real local env file only outside git:
#   - .env.local for local development
#   - Vercel Environment Variables for Preview / Production
# Never commit real secrets.

# -----------------------------------------------------------------------------
# Runtime identity
# Public/private: mixed
# Environments: development, preview, staging, production
# -----------------------------------------------------------------------------
APP_ENV=development
DATABASE_ENV=development
# NODE_ENV is managed by Next.js or the runtime. Do not hardcode in committed env files.
# VERCEL_ENV is managed by Vercel. Do not commit a real value here.
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000
APP_URL=http://127.0.0.1:3000
# Reserved compatibility variable. Not currently consumed directly.
NEXTAUTH_URL=http://127.0.0.1:3000

# -----------------------------------------------------------------------------
# Database connection
# Public/private: private
# Environments: all server-side environments
# -----------------------------------------------------------------------------
DATABASE_URL=mysql://DEV_USER:DEV_PASSWORD@DEV_HOST:3306/gogi_dev
# Optional direct/admin connection string for tooling. Leave blank unless needed.
DIRECT_URL=mysql://DEV_USER:DEV_PASSWORD@DEV_HOST:3306/gogi_dev
DB_HOST=DEV_HOST
DB_PORT=3306
DB_NAME=gogi_dev
DB_USER=DEV_USER
DB_PASSWORD=DEV_PASSWORD
# Legacy alias used by older scripts. Keep synchronized with DB_PASSWORD if used.
DB_PASS=DEV_PASSWORD
DB_REQUIRE_SSL=false
# Use either DB_SSL_CA or DB_CA when TLS requires a CA bundle. Never store real certs inline in git.
DB_SSL_CA=
DB_CA=
DB_POOL_CONNECTION_LIMIT=3
DB_POOL_QUEUE_LIMIT=25
PRISMA_CONNECTION_LIMIT=3
PRISMA_POOL_TIMEOUT=20

# -----------------------------------------------------------------------------
# Production reference fingerprints for staging safety checks
# Public/private: private but non-secret metadata
# Environments: preview, staging, test
# -----------------------------------------------------------------------------
PRODUCTION_DB_NAME=gogi_prod
PRODUCTION_DB_HOST_FINGERPRINT=PROD_HOST_FINGERPRINT_PLACEHOLDER
PRODUCTION_DB_USER_FINGERPRINT=PROD_USER_FINGERPRINT_PLACEHOLDER

# -----------------------------------------------------------------------------
# Authentication and sessions
# Public/private: private
# Environments: server-side only
# -----------------------------------------------------------------------------
JWT_SECRET=REPLACE_WITH_A_MINIMUM_32_CHAR_SECRET_FOR_JWT_SIGNING
NEXTAUTH_SECRET=REPLACE_WITH_A_MINIMUM_32_CHAR_SECRET_FOR_NEXTAUTH
# Reserved compatibility variable. Not currently consumed directly.
AUTH_SECRET=REPLACE_WITH_A_MINIMUM_32_CHAR_SECRET_FOR_AUTH
SESSION_SECRET=REPLACE_WITH_A_MINIMUM_32_CHAR_SECRET_FOR_SESSIONS
ADMIN_SECRET=REPLACE_WITH_A_MINIMUM_32_CHAR_SECRET_FOR_ADMIN_ACTIONS
AUTH_COOKIE_DOMAIN=localhost
AUTH_SESSION_HOURS=12
JWT_EXPIRES_IN=12h
JWT_EXPIRATION=12h

# -----------------------------------------------------------------------------
# Mercado Pago
# Public/private: mixed
# Environments: preview, staging, production
# -----------------------------------------------------------------------------
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=APP_PUBLIC_KEY_PLACEHOLDER
MERCADOPAGO_ACCESS_TOKEN=APP_ACCESS_TOKEN_PLACEHOLDER
MERCADOPAGO_WEBHOOK_SECRET=REPLACE_WITH_A_MINIMUM_32_CHAR_WEBHOOK_SECRET
NEXT_PUBLIC_MERCADOPAGO_DEBUG=0

# -----------------------------------------------------------------------------
# Bank transfer display fields
# Public/private: public
# Environments: frontend checkout
# -----------------------------------------------------------------------------
NEXT_PUBLIC_TRANSFER_BANK=Banco de Prueba
NEXT_PUBLIC_TRANSFER_HOLDER=Titular de Prueba
NEXT_PUBLIC_TRANSFER_CLABE=000000000000000000
NEXT_PUBLIC_TRANSFER_ACCOUNT_NUMBER=0000000000

# -----------------------------------------------------------------------------
# Email delivery
# Public/private: private
# Environments: server-side only
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_test_placeholder_do_not_use
EMAIL_FROM=Gogi Eats <staging@example.test>
EMAIL_VERIFICATION_ENABLED=true
SMTP_HOST=smtp.example.test
SMTP_USER=qa_smtp_user
SMTP_PASS=qa_smtp_password

# -----------------------------------------------------------------------------
# Media / storage
# Public/private: private
# Environments: server-side only
# -----------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=demo-staging-cloud
CLOUDINARY_API_KEY=1234567890
CLOUDINARY_API_SECRET=cloudinary_secret_placeholder
# Reserved future storage variables. Not currently used in code.
STORAGE_BUCKET_NAME=qa-staging-bucket
AWS_ACCESS_KEY_ID=AWS_ACCESS_KEY_ID_PLACEHOLDER
AWS_SECRET_ACCESS_KEY=AWS_SECRET_ACCESS_KEY_PLACEHOLDER

# -----------------------------------------------------------------------------
# Maps / monitoring (reserved placeholders)
# Public/private: mixed
# Environments: not currently wired in code
# -----------------------------------------------------------------------------
NEXT_PUBLIC_MAPS_API_KEY=maps_public_placeholder
SENTRY_DSN=https://public@example.ingest.sentry.io/123456

# -----------------------------------------------------------------------------
# Security / hashing
# Public/private: private
# Environments: server-side only
# -----------------------------------------------------------------------------
PASSWORD_PEPPER=REPLACE_WITH_A_MINIMUM_32_CHAR_PASSWORD_PEPPER
PASSWORD_RESET_TOKEN_MINUTES=30
SALT_ROUNDS=12

# -----------------------------------------------------------------------------
# Internal tooling / seeds
# Public/private: private
# Environments: local, preview, staging, test
# -----------------------------------------------------------------------------
ENABLE_INTERNAL_TOOLS=false
ALLOW_STAGING_DB_WRITES=false
SEED_DEMO_DATA=false
